  {
    "type": "maltekstseksjon",
    "section": "section-sel",
    "textIdList": [
      "1350e59e-62f6-4160-9535-693a69c08a9f",
      "80062f28-535d-46b6-bc84-2352bb4c0a84",
      "57d14f27-2cee-4fe9-af4d-3aed32d03e9d",
      "6994a9cb-4f43-4055-bbbd-f79a6791561f"
    ],
    "language": "nb",
    "children": [
      {
        "type": "maltekst",
        "section": "section-sel",
        "id": "1350e59e-62f6-4160-9535-693a69c08a9f",
        "language": "nb",
        "children": [
          {
            "type": "h2",
            "children": [
              {
                "text": "Du har rett til innsyn"
              }
            ]
          },
          {
            "type": "p",
            "align": "left",
            "children": [
              {
                "text": "Du har rett til å se dokumentene i saken din. Dette følger av forvaltningsloven § 18. Du kan lese mer om innsynsretten på nav.no/personvernerklaering."
              }
            ],
            "indent": 0
          }
        ],
        "_id": "1350e59e-62f6-4160-9535-693a69c08a9f"
      },
      {
        "type": "maltekst",
        "section": "section-sel",
        "id": "80062f28-535d-46b6-bc84-2352bb4c0a84",
        "language": "nb",
        "children": [
          {
            "type": "h2",
            "align": "left",
            "children": [
              {
                "text": "Du har rettigheter knyttet til personopplysningene dine "
              }
            ]
          },
          {
            "type": "p",
            "align": "left",
            "children": [
              {
                "text": "Du finner informasjon om hvordan Nav behandler personopplysningene dine, og hvilke rettigheter du har, på nav.no/personvernerklaering. "
              }
            ]
          }
        ],
        "_id": "80062f28-535d-46b6-bc84-2352bb4c0a84"
      },
      {
        "type": "maltekst",
        "section": "section-sel",
        "id": "57d14f27-2cee-4fe9-af4d-3aed32d03e9d",
        "language": "nb",
        "children": [
          {
            "type": "h2",
            "children": [
              {
                "text": "Du har rett til å få hjelp fra andre",
                "bold": true
              },
              {
                "text": " "
              }
            ]
          },
          {
            "type": "p",
            "align": "left",
            "children": [
              {
                "text": "Du kan be om hjelp fra andre under hele saksbehandlingen, for eksempel fra en advokat, rettshjelper, en organisasjon du er medlem av, eller en myndig person over 18 år. Dette følger av forvaltningsloven § 12. Hvis den som hjelper deg ikke er advokat, må du gi denne personen skriftlig fullmakt. Bruk skjemaet du finner på nav.no/fullmakt. "
              }
            ]
          },
          {
            "type": "p",
            "align": "left",
            "children": [
              {
                "text": "Informasjon om fri rettshjelp får du hos Statsforvalteren eller advokat."
              }
            ]
          }
        ],
        "_id": "57d14f27-2cee-4fe9-af4d-3aed32d03e9d"
      },
      {
        "type": "maltekst",
        "section": "section-sel",
        "id": "6994a9cb-4f43-4055-bbbd-f79a6791561f",
        "language": "nb",
        "children": [
          {
            "type": "h2",
            "children": [
              {
                "text": "Har du spørsmål?"
              }
            ]
          },
          {
            "type": "p",
            "align": "left",
            "children": [
              {
                "text": "Du finner mer informasjon på nav.no."
              }
            ],
            "indent": 0
          },
          {
            "type": "p",
            "align": "left",
            "indent": 0,
            "children": [
              {
                "text": "På nav.no/kontakt kan du chatte eller skrive til oss."
              }
            ]
          },
          {
            "type": "p",
            "align": "left",
            "children": [
              {
                "text": "Hvis du ikke finner svar på nav.no, kan du ringe oss på telefon 55 55 33 33, hverdager 09.00-15.00.\n\n\nMed hilsen\nArbeids- og velferdsdirektoratet Klageinstans"
              }
            ],
            "indent": 0
          }
        ],
        "_id": "6994a9cb-4f43-4055-bbbd-f79a6791561f"
      }
    ],
